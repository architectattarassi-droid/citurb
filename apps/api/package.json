{
  "name": "apps-api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prestart:dev": "npm run prisma:generate && npm run prisma:generate:dossiers",
    "start:dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "start:fast": "ts-node-dev --transpile-only -r tsconfig-paths/register src/main.ts",
    "start:prod": "node -r tsconfig-paths/register dist/main.js",
    "build": "nest build",
    "lint": "eslint .",
    "prisma:generate": "node ../../node_modules/prisma/build/index.js generate --schema ../../prisma/schema.prisma",
    "prisma:generate:dossiers": "node ../../node_modules/prisma/build/index.js generate --schema ../../prisma/dossiers/schema.prisma",
    "prisma:migrate": "node ../../node_modules/prisma/build/index.js migrate dev --schema ../../prisma/schema.prisma",
    "prisma:reset": "node ../../node_modules/prisma/build/index.js migrate reset --schema ../../prisma/schema.prisma",
    "prisma:studio": "node ../../node_modules/prisma/build/index.js studio --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@citurbarea/config": "file:../../packages/config",
    "@citurbarea/contracts": "file:../../packages/contracts",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.5",
    "@prisma/client": "^5.0.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "eslint": "^9.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  }
}
